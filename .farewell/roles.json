{
  "schema_version": 3,
  "org_registry": ["LEADER_1", "LEADER_2", "SPECIAL", "WORKER"],
  "resolve": {
    "LEADER_1": { "role": "orchestrator", "agent": "orchestrator" },
    "LEADER_2": { "role": "orchestrator", "agent": "orchestrator" },
    "SPECIAL":  { "role": "executor",    "agent": "build" },
    "WORKER":   { "role": "executor",    "agent": "build" }
  },
  "agent_map": {
    "security-review":     "security-reviewer",
    "verification-loop":   "tdd-guide",
    "self-heal":           "build-error-resolver",
    "deploy":              "build",
    "rust-debug":           "build",
    "kotlin-debug":         "build",
    "default":             "build"
  },
  "worker_pool": {
    "strategy": "round_robin",
    "scribe_index": 4
  },
  "plan_agents": ["planner", "architect", "docs-lookup"],
  "task_model_preferences": {
    "feature": {"model": "SPECIAL", "reason": "100% success from 30 tasks"},
    "fix": {"model": "SPECIAL", "reason": "100% success from 15 tasks"},
    "deploy": {"model": "LEADER_1", "reason": "100% success from 9 tasks"}
  }
}
