{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/${LEADER}",
  "small_model": "9router/${LEADER}",
  "default_agent": "build",

  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local 9Router",
      "env": ["NINEROUTER_API_KEY"],
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}"
      },
      "models": ${MODELS_JSON}
    }
  },

  "instructions": [
    ".opencode/work-mode.json",
    ".opencode/context.md",
    "instructions/rules.md",
    ".farewell/context/farewell-agent.md",
    "ecc/AGENTS.md",
    ".opencode/footer.md"
  ],

  "skills": {
    "paths": ${SKILL_PATHS}
  },

  "agent": {
    "build": {
      "description": "Primary coding agent (fallback untuk model non-org)",
      "mode": "primary",
      "model": "9router/${LEADER}",
      "tools": { "write": true, "edit": true, "bash": true, "read": true, "changed-files": true }
    },
    "team": {
      "description": "Orchestrator — delegasi, bukan eksekusi",
      "mode": "primary",
      "model": "9router/${SPECIAL}",
      "prompt": "{file:.opencode/prompts/team-orchestrator.txt}",
      "tools": { "read": true, "bash": true }
    },
    "director": {
      "description": "Director AI — strategic review",
      "mode": "subagent",
      "model": "9router/${LEADER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true }
    },
    "deputy-director": {
      "description": "Deputy Director AI — validation",
      "mode": "subagent",
      "model": "9router/${LEADER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/architect.txt}",
      "tools": { "read": true, "bash": true }
    },
    "senior-engineer": {
      "description": "Executor — nulis kode",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:.opencode/prompts/senior-engineer.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "junior-reviewer": {
      "description": "Junior Reviewer — validasi kode",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:.opencode/prompts/junior-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "planner": {
      "description": "Planning specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true }
    },
    "architect": {
      "description": "Architecture specialist",
      "mode": "subagent",
      "model": "9router/${SPECIAL}",
      "prompt": "{file:ecc/.opencode/prompts/agents/architect.txt}",
      "tools": { "read": true, "bash": true }
    },
    "code-reviewer": {
      "description": "Code review specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "security-reviewer": {
      "description": "Security specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "tdd-guide": {
      "description": "TDD specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": { "read": true, "bash": true }
    },
    "build-error-resolver": {
      "description": "Build error specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "doc-updater": {
      "description": "Documentation specialist",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/doc-updater.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "python-reviewer": {
      "description": "Python code review",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "typescript-reviewer": {
      "description": "TypeScript/JS code review",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "database-reviewer": {
      "description": "SQL/schema review",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/database-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "docs-lookup": {
      "description": "Documentation lookup",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/docs-lookup.txt}",
      "tools": { "read": true, "bash": true }
    },
    "refactor-cleaner": {
      "description": "Dead code & refactoring",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "ketua-tim": {
      "description": "Lead — teknis, koordinasi",
      "mode": "subagent",
      "model": "9router/${SPECIAL}",
      "prompt": "{file:.opencode/prompts/team-orchestrator.txt}",
      "tools": { "read": true, "bash": true }
    },
    "backend-reviewer": {
      "description": "Backend audit",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    },
    "frontend-reviewer": {
      "description": "Frontend audit",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true }
    }
  },

  "command": {
    "repl": {
      "description": "REPL mode — natural language, auto-action",
      "template": "py -m farewell_agent repl $ARGUMENTS"
    },
    "setup-project": {
      "description": "Register project + extract guide + switch",
      "template": "py -m farewell_agent setup-project $ARGUMENTS"
    },
    "start-project": {
      "description": "Auto-detect & register current dir",
      "template": "py -m farewell_agent start-project $ARGUMENTS"
    },
    "daily": {
      "description": "Start 9Router + npm update + sync + readiness",
      "template": "py -m farewell_agent daily $ARGUMENTS"
    },
    "evolution": {
      "description": "Pull 5 tools repo + extract + auto-apply",
      "template": "py -m farewell_agent evolution $ARGUMENTS"
    },
    "status": {
      "description": "Show current state",
      "template": "py -m farewell_agent status $ARGUMENTS"
    },
    "project": {
      "description": "List or switch active project",
      "template": "py -m farewell_agent project $ARGUMENTS"
    },
    "run": {
      "description": "Run a task via OpenCode",
      "template": "py -m farewell_agent run $ARGUMENTS"
    },
    "memory": {
      "description": "View / edit project memory",
      "template": "py -m farewell_agent memory $ARGUMENTS"
    },
    "org": {
      "description": "Organization hierarchy",
      "template": "py -m farewell_agent org $ARGUMENTS"
    }
  },

  "permission": {
    "mcp_*": "ask"
  }
}
